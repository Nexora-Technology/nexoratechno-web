# ─── Docker Compose (host-side) ──────────────────────────────
# Ports exposed on the host. Change these to match your Nginx upstream config.
WEB_PORT=3000
WP_PORT=8080

# ─── WordPress Database ──────────────────────────────────────
WP_DB_NAME=nexora_wp
WP_DB_USER=nexora_wp
WP_DB_PASSWORD=nexora_wp_pass
WP_DB_ROOT_PASSWORD=nexora_root_pass

# ─── WordPress Admin Account ─────────────────────────────────
# Created automatically on first container start.
# IMPORTANT: Set WP_ADMIN_PASSWORD to a strong value before first run.
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me_before_first_run
WP_ADMIN_EMAIL=admin@nexoratechno.com

# ─── WordPress Public URL ────────────────────────────────────
# Next.js proxies /wp-admin, /wp-login.php, /wp-content/*, /graphql to the WP container,
# so admin + frontend share one origin.
# Local dev:   http://localhost:3000
# Production:  https://nexoratechno.com
WP_PUBLIC_URL=http://localhost:3000

# ─── Next.js → WPGraphQL ─────────────────────────────────────
# In docker-compose the web container uses http://wordpress/graphql (internal).
# Override here only when running Next.js locally WITHOUT docker.
WPGRAPHQL_URL=http://localhost:8080/graphql

# ─── Contact Form SMTP (iRedMail) ────────────────────────────
SMTP_HOST=smtp.nexoratechno.com
SMTP_PORT=587
SMTP_USER=contact@nexoratechno.com
SMTP_PASS=your_password_here
SMTP_FROM=contact@nexoratechno.com
